generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Survey {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  description String
  instructions Json
  options     Json
  dimensions  Json
  questions   Json
  resultBands Json         @default("[]")
  notes       Json         @default("[]")
  evaluationNotes Json     @default("[]")
  dominantLabel String     @default("主导应对姿态")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  submissions Submission[]
}

model Submission {
  id          String   @id @default(cuid())
  surveyId    String
  respondent  String
  answers     Json
  result      Json
  durationSeconds Int?
  createdAt   DateTime @default(now())
  survey      Survey   @relation(fields: [surveyId], references: [id])

  @@index([surveyId, createdAt])
}
